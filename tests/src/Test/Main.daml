module Test.Main where

import Daml.Script
import DA.Date (date, Month(..))
import DA.Time (time, days)
import Splice.Api.Token.MetadataV1 (emptyChoiceContext)

import Types
import Series
import qualified Vault
import OptionToken (UserMetadata(..), Split(..), Transfer(..))

allocate : Text -> Script Party
allocate n = allocateParty n

mkSeries : Party -> Party -> Party -> SeriesStatus -> Script (ContractId OptionSeries)
mkSeries operator oracle house status = submit operator do
  createCmd OptionSeries with
    operator
    oracle
    house
    seriesRef = "SERIES-BTC-DAILY-001"
    underlying = "BTCUSD"
    strikePrice = 100.0
    feeRate = 0.01
    collateralAsset = "CC"
    startTime = time (date 1970 Jan 1) 0 0 0
    endTime = time (date 1970 Jan 2) 0 0 0
    expiryTime = time (date 1970 Jan 3) 0 0 0
    cadence = Daily
    status
    settlement = None

testHybridLifecycle : Script ()
testHybridLifecycle = script do
  operator <- allocate "Operator"
  oracle <- allocate "Oracle"
  house <- allocate "House"
  alice <- allocate "Alice"
  bob <- allocate "Bob"

  seriesCid <- mkSeries operator oracle house Active

  vault0 <- submit operator do
    createCmd Vault.CollateralVault with
      operator
      house
      seriesRef = "SERIES-BTC-DAILY-001"
      ccReserve = 100.0
      initialSeedLiquidity = 100.0
      additionalSeedLiquidity = 0.0
      totalSetsMinted = 0.0
      settlementDone = False

  -- Additional post-creation seed.
  (vault0b, _) <- submit operator do
    exerciseCmd vault0 Vault.AddSeedLiquidity with
      amount = 10.0
      metadata = UserMetadata with
        externalUserId = Some "system-operator"
        userMemo = Some "seed-top-up"
      choiceContext = emptyChoiceContext
      reason = "INITIAL_SEED_TOPUP"
      featuredAppRightCid = None

  (vault0c, _) <- submit operator do
    exerciseCmd vault0b Vault.RemoveSeedLiquidity with
      amount = 3.0
      metadata = UserMetadata with
        externalUserId = Some "system-operator"
        userMemo = Some "seed-withdraw"
      choiceContext = emptyChoiceContext
      reason = "SEED_WITHDRAW"
      featuredAppRightCid = None

  -- BUY 1: Alice wants CALL, unwanted PUT goes to house.
  (vault1, aliceCall10, housePut10, _) <- submit operator do
    exerciseCmd vault0c Vault.MintCompleteSets with
      trader = alice
      desiredSide = Call
      quantity = 10.0
      depositAmount = 12.0
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      metadata = UserMetadata with
        externalUserId = Some "user-alice-001"
        userMemo = Some "buy-call-10"
      reason = "BUY_CALL_TRADE"

  aliceCall10Q <- queryContractId alice aliceCall10
  assertMsg "Alice should own 10 CALL tokens"
    (fmap (.quantity) aliceCall10Q == Some 10.0)

  -- SELL partial: Alice returns 5 CALL to house, then vault pays sell proceeds.
  (aliceCall5ToSell, aliceCall5Remain) <- submit alice do
    exerciseCmd aliceCall10 Split with splitQty = 5.0

  houseCall5 <- submit alice do
    exerciseCmd aliceCall5ToSell Transfer with newOwner = house

  (vault2, sellPayoutCid, _) <- submit operator do
    exerciseCmd vault1 Vault.ReleasePayout with
      trader = alice
      soldTokenCid = houseCall5
      amount = 1.0
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      reason = "SELL_PAYOUT"
      metadata = UserMetadata with
        externalUserId = Some "user-alice-001"
        userMemo = Some "sell-call-5"

  sellPayoutQ <- queryContractId alice sellPayoutCid
  assertMsg "Sell payout should be created for Alice"
    (fmap (.amount) sellPayoutQ == Some 1.0)

  -- BUY 2: Bob wants PUT, unwanted CALL goes to house.
  (vault3, bobPut8, houseCall8, _) <- submit operator do
    exerciseCmd vault2 Vault.MintCompleteSets with
      trader = bob
      desiredSide = Put
      quantity = 8.0
      depositAmount = 9.0
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      metadata = UserMetadata with
        externalUserId = Some "user-bob-002"
        userMemo = Some "buy-put-8"
      reason = "BUY_PUT_TRADE"

  -- Resolve: CALL wins (resolved price > strike).
  passTime (days 2)
  settledSeriesCid <- submit oracle do
    exerciseCmd seriesCid SubmitSettlement with resolvedPrice = 140.0

  -- Settle and pay atomically: winning side = CALL.
  (recordCid, winnerPayoutCids, _) <- submit operator do
    exerciseCmd vault3 Vault.SettleAndPay with
      seriesCid = settledSeriesCid
      winningTokenCids = [houseCall5, aliceCall5Remain, houseCall8]
      losingTokenCids = [housePut10, bobPut8]
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      metadata = UserMetadata with
        externalUserId = Some "system-operator"
        userMemo = Some "finalize-series-001"
      reason = "SERIES_SETTLEMENT_FINALIZED"

  recordQ <- queryContractId operator recordCid
  assertMsg "Settlement record should exist" (recordQ /= None)

  case recordQ of
    Some r -> do
      assertMsg "Winning side should be CALL" (r.winningSide == Call)
      assertMsg "Total sets minted should be 18" (r.totalSetsMinted == 18.0)
      assertMsg "External payout should equal Alice winning qty"
        (r.externalWinnerPayout == 5.0)
      assertMsg "House residual should match reserve minus payout"
        (r.houseResidual == 122.0)
    None -> abort "Expected settlement record"

  -- Only Alice should have an external settlement payout (house winners are not paid out).
  assertMsg "Exactly one external winner payout expected" (length winnerPayoutCids == 1)

  pure ()

testNegativeChecks : Script ()
testNegativeChecks = script do
  operator <- allocate "NegOperator"
  oracle <- allocate "NegOracle"
  house <- allocate "NegHouse"
  alice <- allocate "NegAlice"

  -- Use a far-future series so this negative check is stable even after passTime
  -- in other tests.
  seriesCid <- submit operator do
    createCmd OptionSeries with
      operator
      oracle
      house
      seriesRef = "SERIES-BTC-DAILY-NEG"
      underlying = "BTCUSD"
      strikePrice = 100.0
      feeRate = 0.01
      collateralAsset = "CC"
      startTime = time (date 1970 Jan 10) 0 0 0
      endTime = time (date 1970 Jan 11) 0 0 0
      expiryTime = time (date 1970 Jan 12) 0 0 0
      cadence = Daily
      status = Active
      settlement = None

  vaultCid <- submit operator do
    createCmd Vault.CollateralVault with
      operator
      house
      seriesRef = "SERIES-BTC-DAILY-001"
      ccReserve = 20.0
      initialSeedLiquidity = 20.0
      additionalSeedLiquidity = 0.0
      totalSetsMinted = 0.0
      settlementDone = False

  -- Unauthorized mint attempt.
  submitMustFail alice do
    exerciseCmd vaultCid Vault.MintCompleteSets with
      trader = alice
      desiredSide = Call
      quantity = 1.0
      depositAmount = 1.2
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      metadata = UserMetadata with
        externalUserId = Some "neg-user-alice"
        userMemo = Some "unauthorized-mint"
      reason = "UNAUTHORIZED_MINT_ATTEMPT"

  -- Settlement before end-time should fail when series not ended and wall-clock < endTime.
  submitMustFail oracle do
    exerciseCmd seriesCid SubmitSettlement with resolvedPrice = 110.0

  -- Release payout cannot breach collateral floor.
  (vault1, _, houseCall5Neg, _) <- submit operator do
    exerciseCmd vaultCid Vault.MintCompleteSets with
      trader = alice
      desiredSide = Put
      quantity = 5.0
      depositAmount = 5.0
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      metadata = UserMetadata with
        externalUserId = Some "neg-user-alice"
        userMemo = Some "neg-buy"
      reason = "NEGATIVE_BUY"

  submitMustFail operator do
    exerciseCmd vault1 Vault.ReleasePayout with
      trader = alice
      soldTokenCid = houseCall5Neg
      amount = 21.0
      featuredAppRightCid = None
      choiceContext = emptyChoiceContext
      reason = "INVALID_PAYOUT"
      metadata = UserMetadata with
        externalUserId = Some "neg-user-alice"
        userMemo = Some "invalid-release"

  -- Cannot remove more seed than tracked as additional seed.
  submitMustFail operator do
    exerciseCmd vault1 Vault.RemoveSeedLiquidity with
      amount = 100.0
      metadata = UserMetadata with
        externalUserId = Some "neg-operator"
        userMemo = Some "invalid-seed-remove"
      choiceContext = emptyChoiceContext
      reason = "INVALID_SEED_REMOVE"
      featuredAppRightCid = None

  pure ()

setup : Script ()
setup = script do
  debug "Running raven-contracts tests..."
  testHybridLifecycle
  debug "  testHybridLifecycle passed"
  testNegativeChecks
  debug "  testNegativeChecks passed"
  debug "All tests passed."
  pure ()
